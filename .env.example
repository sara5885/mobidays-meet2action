# LLM provider: mock | gemini | ollama
LLM_PROVIDER=mock

# Gemini 사용 시 (https://aistudio.google.com 에서 발급)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama 사용 시 (로컬 LLM, 무료·무제한·온프레미스)
#   설치: brew install ollama  →  ollama serve  →  ollama pull qwen2.5:7b
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# 스키마 위반 시 재시도 횟수
MAX_LLM_RETRIES=2
