{
  "meeting_id": "ko_meeting_3speakers_4min_faster-stt",
  "title": "ko_meeting_3speakers_4min_faster (Whisper STT)",
  "advertiser": "",
  "date": "2026-06-02",
  "language": "ko",
  "note": "pure Whisper transcription (no LLM/diarization)",
  "segments": [
    {
      "id": 1,
      "start": 0.0,
      "text": "자 다들 들어오셨나?"
    },
    {
      "id": 2,
      "start": 2.0,
      "text": "오늘은 노바드림 다음달 캠페인 전에"
    },
    {
      "id": 3,
      "start": 4.7,
      "text": "정리할게 좀 있어서"
    },
    {
      "id": 4,
      "start": 6.2,
      "text": "한 세가지 정도 보면 될 것 같은데"
    },
    {
      "id": 5,
      "start": 8.4,
      "text": "일단 시작해볼게요"
    },
    {
      "id": 6,
      "start": 10.0,
      "text": "네 채널된 성과랑 예산 대본 좀 보고"
    },
    {
      "id": 7,
      "start": 12.9,
      "text": "아 그리고 타겟 세그먼트 누락된 거 있어서"
    },
    {
      "id": 8,
      "start": 15.4,
      "text": "그것도 같이 봐야 할 것 같아요"
    },
    {
      "id": 9,
      "start": 17.5,
      "text": "저는 메인 비주얼 컨셉이란 카피톤 정도"
    },
    {
      "id": 10,
      "start": 20.9,
      "text": "근데 랜딩은 아직 손못됐어요"
    },
    {
      "id": 11,
      "start": 23.2,
      "text": "어제까지 다른 건 끝내내라"
    },
    {
      "id": 12,
      "start": 25.5,
      "text": "어 그게 랜딩까지 같이 봐야 광고주가 그림이 그려질 텐데"
    },
    {
      "id": 13,
      "start": 29.9,
      "text": "일단 일정부터 보면 다음 주 목요일 오후까지였나요?"
    },
    {
      "id": 14,
      "start": 33.4,
      "text": "제안서가"
    },
    {
      "id": 15,
      "start": 34.8,
      "text": "목요일이긴 한데"
    },
    {
      "id": 16,
      "start": 35.9,
      "text": "그게 지난 캠페인 전환 수치가 좀 이상해서요"
    },
    {
      "id": 17,
      "start": 39.1,
      "text": "메타랑 GA 숫자가 안 맞아요"
    },
    {
      "id": 18,
      "start": 41.2,
      "text": "이좀 집계인 것 같긴 한데 확신은 아직"
    },
    {
      "id": 19,
      "start": 44.0,
      "text": "어 그거 저번에도 한 번 그러지 않았어요?"
    },
    {
      "id": 20,
      "start": 47.1,
      "text": "그때도 픽셀 문제였던 것 같은데"
    },
    {
      "id": 21,
      "start": 49.8,
      "text": "비슷한 것 같아요"
    },
    {
      "id": 22,
      "start": 51.1,
      "text": "근데 그때는 그냥 넘어갔잖아요"
    },
    {
      "id": 23,
      "start": 53.0,
      "text": "광고주가 별 말 없어서"
    },
    {
      "id": 24,
      "start": 55.3,
      "text": "음 이번에는 어쨌든 숫자가 안 맞으면 제안 자체가 흔들리니까"
    },
    {
      "id": 25,
      "start": 59.2,
      "text": "수아님 이거 얼마나 걸려요?"
    },
    {
      "id": 26,
      "start": 61.6,
      "text": "원인은 거의 본 것 같은데"
    },
    {
      "id": 27,
      "start": 63.5,
      "text": "픽셀 이벤트가 중복 발화되는 건 맞아 보이고요"
    },
    {
      "id": 28,
      "start": 66.3,
      "text": "보정해서 다시 돌리는데 한 하루 안에는 가능할 것 같아요"
    },
    {
      "id": 29,
      "start": 70.9,
      "text": "일단 그럼 그거 끝나야 제안서 마무리 들어가는 걸로"
    },
    {
      "id": 30,
      "start": 74.7,
      "text": "근데 그렇다고 다른 거 멈추진 말고요"
    },
    {
      "id": 31,
      "start": 77.4,
      "text": "아 그러면 비주얼은 어떤 숫자 보고 톤 잡아요?"
    },
    {
      "id": 32,
      "start": 81.2,
      "text": "저번 캠페인 인사이트 비단이 있는 거잖아요 결국"
    },
    {
      "id": 33,
      "start": 84.3,
      "text": "그건 일단 보정 전 베이터로라도 톤은 잡아도 될 것 같은데"
    },
    {
      "id": 34,
      "start": 89.1,
      "text": "아닌가?"
    },
    {
      "id": 35,
      "start": 90.9,
      "text": "어 그건 일단 두고 봐요"
    },
    {
      "id": 36,
      "start": 92.8,
      "text": "두 번째 얘기 잠깐 할게요"
    },
    {
      "id": 37,
      "start": 94.9,
      "text": "채널 비중인데 유튜브 일주차부터 같이 가는 거 어떻게 생각해요?"
    },
    {
      "id": 38,
      "start": 99.0,
      "text": "솔직히 유튜브는 좀 부담이에요"
    },
    {
      "id": 39,
      "start": 102.1,
      "text": "영상 소재 리드 타임이 길고"
    },
    {
      "id": 40,
      "start": 104.4,
      "text": "일주차에 무리하게 넣으면 톤이 안 잡힌 채로 나갈 것 같아요"
    },
    {
      "id": 41,
      "start": 108.9,
      "text": "저도 첫 주는 메타란 인스타 위주가 안전할 것 같긴 한데"
    },
    {
      "id": 42,
      "start": 112.5,
      "text": "광고주가 유튜브 얘기를 먼저 꺼냈잖아요 저번 미팅에서"
    },
    {
      "id": 43,
      "start": 116.8,
      "text": "아 그랬죠 그래서 좀 고민이긴 해요"
    },
    {
      "id": 44,
      "start": 119.7,
      "text": "일단 우리 안에서는 메타 먼저"
    },
    {
      "id": 45,
      "start": 121.7,
      "text": "유튜브는 2주차쯤 붙이는 걸로"
    },
    {
      "id": 46,
      "start": 123.7,
      "text": "잠정적으로 광고주한테는 옵션으로 같이 들고 가는 걸로 합시다"
    },
    {
      "id": 47,
      "start": 128.2,
      "text": "그럼 비주얼 카드 순서랑 빈슬로 짜리 카피는"
    },
    {
      "id": 48,
      "start": 131.4,
      "text": "제가 오늘 저녁에 음 늦으면 내일 오전에 정리해둘게요"
    },
    {
      "id": 49,
      "start": 135.9,
      "text": "캠페인 세트 분리는 제가 수요일 오전까지 해놓을게요"
    },
    {
      "id": 50,
      "start": 139.2,
      "text": "근데 이건 운영 계정에서 켜고 끄는 거라"
    },
    {
      "id": 51,
      "start": 141.6,
      "text": "광고주 컨펌 한 번 받고 가야 할 거예요"
    },
    {
      "id": 52,
      "start": 144.7,
      "text": "어 그거 컨펌은 누가 받기로 했죠?"
    },
    {
      "id": 53,
      "start": 147.4,
      "text": "아 내가 받기로 했었나?"
    },
    {
      "id": 54,
      "start": 149.3,
      "text": "그건 이따 슬랙으로 정리하고요"
    },
    {
      "id": 55,
      "start": 151.4,
      "text": "세번째가 카피 톤이었는데"
    },
    {
      "id": 56,
      "start": 153.8,
      "text": "지금 카피가 좀 딱딱하다는 얘기 있었잖아요"
    },
    {
      "id": 57,
      "start": 156.6,
      "text": "기능 설명 위주라 차가워 보이고"
    },
    {
      "id": 58,
      "start": 158.6,
      "text": "할인 종료 알림도 좀 압박처럼 읽혀요"
    },
    {
      "id": 59,
      "start": 161.7,
      "text": "근데 그 헤드라인 지금 AB 돌보 있는 거라서"
    },
    {
      "id": 60,
      "start": 165.1,
      "text": "한 번에 다 바꾸면 비교가 좀 깨져요"
    },
    {
      "id": 61,
      "start": 168.2,
      "text": "아 맞다 AB 돌보 있었지"
    },
    {
      "id": 62,
      "start": 171.0,
      "text": "그럼 뭐 다 바꾸진 말고 일보만?"
    },
    {
      "id": 63,
      "start": 173.7,
      "text": "체리님 꼭 바꿔야 하는 거 어디에요?"
    },
    {
      "id": 64,
      "start": 176.5,
      "text": "메인 헤드라인 렌딩 첫 화면 CTA 버튼"
    },
    {
      "id": 65,
      "start": 180.4,
      "text": "이 3개는 진짜 무조건 손 봐야 해요"
    },
    {
      "id": 66,
      "start": 183.3,
      "text": "나머지는 뭐 캠페인 중단에 바꿔도"
    },
    {
      "id": 67,
      "start": 186.1,
      "text": "큰 차이 없을 것 같고"
    },
    {
      "id": 68,
      "start": 187.7,
      "text": "그럼 그 3개만 먼저"
    },
    {
      "id": 69,
      "start": 189.4,
      "text": "아 근데 CTA 바꾸면"
    },
    {
      "id": 70,
      "start": 191.1,
      "text": "전환 추적 이벤트도 다시 봐야 하지 않아요?"
    },
    {
      "id": 71,
      "start": 194.1,
      "text": "봐야 해요 그건 제가 같이 챙길게요"
    },
    {
      "id": 72,
      "start": 196.6,
      "text": "근데 그것도 결국 픽셀 정리 끝나고 나서가 깔끔하긴 해요"
    },
    {
      "id": 73,
      "start": 201.0,
      "text": "아 그리고 하나 더 말씀드릴게요"
    },
    {
      "id": 74,
      "start": 203.4,
      "text": "광고주 쪽에서 신제품 눕기 컷이 아직 안 왔어요"
    },
    {
      "id": 75,
      "start": 206.6,
      "text": "그거 쓰면 체리님이 메인 비주얼을 사실상 못 잡잖아요"
    },
    {
      "id": 76,
      "start": 210.7,
      "text": "어 그거 언제 요청했어요?"
    },
    {
      "id": 77,
      "start": 213.5,
      "text": "오전 10시쯤 담당자에게 요청했는데"
    },
    {
      "id": 78,
      "start": 216.5,
      "text": "아직 답이 없어요"
    },
    {
      "id": 79,
      "start": 218.0,
      "text": "내일 오전까지도 없으면"
    },
    {
      "id": 80,
      "start": 219.7,
      "text": "일단 임시 모겁으로 가야 할 것 같은데"
    },
    {
      "id": 81,
      "start": 222.2,
      "text": "그게 또 검수에서 이상하게 잡힐 수 있어서"
    },
    {
      "id": 82,
      "start": 225.7,
      "text": "자 잠깐 그래서 어떻게 가는 거지?"
    },
    {
      "id": 83,
      "start": 228.4,
      "text": "수아님 그 픽셀 보장 내일 오전까지 다시 돌리는 건"
    },
    {
      "id": 84,
      "start": 231.1,
      "text": "그러면 그대로 가능하시죠?"
    },
    {
      "id": 85,
      "start": 232.8,
      "text": "그게 들어와야 비주얼이고 숫자고 그 다음이 풀려서요"
    },
    {
      "id": 86,
      "start": 236.3,
      "text": "네 오늘 안에 보정하고 내일 오전엔 공유 드릴게요"
    },
    {
      "id": 87,
      "start": 240.0,
      "text": "근데 눕기 컷 안 오면 사실 시안은 어차피 못 잡잖아요"
    },
    {
      "id": 88,
      "start": 244.4,
      "text": "아 그거 어 그건 내가 담당자한테 한 번 더 푸시할게요"
    },
    {
      "id": 89,
      "start": 247.9,
      "text": "오늘 안에 안 오면 임시 컷으로라도 가야 하니까"
    },
    {
      "id": 90,
      "start": 250.7,
      "text": "그건 그렇게 알고 계세요"
    },
    {
      "id": 91,
      "start": 253.4,
      "text": "그럼 저는 비주얼 카드 순서랑 빈 슬롯 카피는"
    },
    {
      "id": 92,
      "start": 256.9,
      "text": "일단 내일 오전까지 1차로 올려놓을게요"
    },
    {
      "id": 93,
      "start": 259.7,
      "text": "필수 카피 세 군데는 시안에 묶어서"
    },
    {
      "id": 94,
      "start": 262.2,
      "text": "금요일까지면 될 것 같긴 한데"
    },
    {
      "id": 95,
      "start": 264.0,
      "text": "근데 헤드라인 손 보면 지금 돌고 있는 AB는 어떻게 돼요?"
    },
    {
      "id": 96,
      "start": 267.6,
      "text": "그냥 깨지는 거잖아요"
    },
    {
      "id": 97,
      "start": 269.3,
      "text": "어차피 헤드라인 새로 들어가면 기존 AB는 한 번 닫고"
    },
    {
      "id": 98,
      "start": 273.0,
      "text": "바꾼 카피로 다시 세팅해야 해요"
    },
    {
      "id": 99,
      "start": 275.4,
      "text": "그건 제가 정리할게요"
    },
    {
      "id": 100,
      "start": 277.1,
      "text": "다만 비교 기간이 한 번 끊기니까"
    },
    {
      "id": 101,
      "start": 279.3,
      "text": "광고주 보고할 때는 그 부분 미리 말씀드리는 게 좋을 것 같아요"
    },
    {
      "id": 102,
      "start": 283.4,
      "text": "어 그럼 캠페인 세트 분리는 수요일 그대로 갈게요"
    },
    {
      "id": 103,
      "start": 287.2,
      "text": "CTA 바뀌면 전환 이벤트도 같이 봐야 한다고"
    },
    {
      "id": 104,
      "start": 289.8,
      "text": "아까 얘기 나왔으니까 그건 같이 묶어서 보고요"
    },
    {
      "id": 105,
      "start": 294.1,
      "text": "좋아요 그리고 채널은 일단 메타랑 인스타 먼저 가고"
    },
    {
      "id": 106,
      "start": 297.7,
      "text": "유튜브는 2주차 옵션으로 제안서에 같이 담으는 거고"
    },
    {
      "id": 107,
      "start": 300.5,
      "text": "광고주 컨펌은 내가 받기로 한 거 맞죠?"
    },
    {
      "id": 108,
      "start": 303.4,
      "text": "네 그렇게 가셨어요"
    },
    {
      "id": 109,
      "start": 306.0,
      "text": "오케이 그럼 일단 이렇게 가보고"
    },
    {
      "id": 110,
      "start": 308.5,
      "text": "눅기 컷이든 픽셀이든 결과 나오는 대로 슬랙에 바로 올려주세요"
    },
    {
      "id": 111,
      "start": 312.6,
      "text": "제안서는 어쨌든 목요일 오후 그대로 가는 거니까"
    }
  ]
}